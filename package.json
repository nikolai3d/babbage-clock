{
  "name": "babbage-clock",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A web-based 3D HTML clock / countdown rendered with three.js.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --reporter=line",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --reporter=line --update-snapshots",
    "test:e2e:docker": "scripts/e2e-docker.sh",
    "test:e2e:docker:update": "scripts/e2e-docker.sh --update-snapshots",
    "capture:demo": "playwright test --config playwright.capture.config.ts --reporter=line",
    "check:base": "node scripts/check-base-path.mjs",
    "test:e2e:live": "playwright test --config playwright.smoke.config.ts --reporter=line",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build && npm run check:base"
  },
  "dependencies": {
    "temporal-polyfill": "^1.0.1",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.61.1",
    "@types/three": "^0.182.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}
